{
    "name": "meta-solver-strategy-lang",
    "description": "Implementation of the Meta Solver Strategy DSL used to express Meta Solver Strategies for the ProvideQ Toolbox.",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "dependencies": {
        "@types/node": "^24.10.1"
    },
    "scripts": {
        "dev": "pnpm -r run dev",
        "build": "pnpm -r run build",
        "build:packages": "pnpm install --filter ./packages/toolbox-api... && pnpm --filter ./packages/toolbox-api... run build && pnpm install --filter ./packages/langium-core... && pnpm --filter ./packages/langium-core... run build",
        "build:editor": "pnpm install && pnpm --filter ./apps/editor... run build",
        "build:interpreter": "pnpm install && pnpm --filter ./apps/interpreter... run build",
        "start": "pnpm -r run start",
        "lint": "pnpm -r run lint",
        "test": "pnpm -r run test",
        "langium": "pnpm --filter ./packages/langium-core... run langium:generate"
    },
    "packageManager": "pnpm@10.30.3",
    "devDependencies": {
        "@types/express": "^4.17.25",
        "@types/node": "^24.10.1",
        "@types/node-notifier": "^8.0.0",
        "@typescript-eslint/eslint-plugin": "~8.47.0",
        "@typescript-eslint/parser": "~8.47.0",
        "eslint": "~9.39.1",
        "ts-node": "10.9.2",
        "typescript": "~5.9.3",
        "vite": "^7.2.4"
    },
    "displayName": "meta-solver-strategy",
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "meta-solver-strategy",
                "aliases": [
                    "Meta Solver Strategy",
                    "meta-solver-strategy"
                ],
                "extensions": [
                    ".mss"
                ],
                "configuration": "./apps/editor/src/editor/language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "meta-solver-strategy",
                "scopeName": "source.meta-solver-strategy",
                "path": "./apps/editor/src/editor/syntaxes/meta-solver-strategy.tmLanguage.json"
            }
        ]
    },
    "activationEvents": [
        "onLanguage:meta-solver-strategy"
    ],
    "main": "./out/extension/main.cjs",
    "bin": {
        "meta-solver-strategy-cli": "./bin/cli.js"
    }
}
